# Public Caddy site address.
# Examples:
# CADDY_SITE=master.example.com
# CADDY_SITE=http://10.0.0.10
CADDY_SITE=master.example.com
ACME_EMAIL=ops@example.com

APP_HTTP_PORT=80
APP_HTTPS_PORT=443

PORT=3000
TZ=Asia/Shanghai

NODE_TYPE=master
NODE_ID=cn-master-01

SESSION_SECRET=replace-with-the-same-long-random-string-on-all-nodes
CRYPTO_SECRET=replace-with-the-same-long-random-string-on-all-nodes

SQL_DSN=postgresql://newapi_user:strong_password@db.internal:5432/new-api
REDIS_CONN_STRING=redis://:strong_password@redis.internal:6379/0

MEMORY_CACHE_ENABLED=true

SQL_MAX_IDLE_CONNS=10
SQL_MAX_OPEN_CONNS=100
SQL_MAX_LIFETIME=300
SQL_MAX_IDLE_TIME=120

REDIS_POOL_SIZE=20

OPTION_SYNC_CHANNEL=new-api:config_sync
OPTION_SYNC_JITTER_MIN_MS=150
OPTION_SYNC_JITTER_MAX_MS=600

TASK_SYNC_CHANNEL=new-api:task_sync
TASK_PENDING_SET_KEY=new-api:tasks:pending
MIDJOURNEY_PENDING_SET_KEY=new-api:midjourney:pending
TASK_POLL_INTERVAL_SECONDS=15
TASK_SYNC_FALLBACK_INTERVAL_SECONDS=60
TASK_PENDING_BATCH_SIZE=200

QUOTA_DATA_FLUSH_THRESHOLD=200
QUOTA_DATA_FLUSH_DEBOUNCE_SECONDS=5

BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_INTERVAL=5

UPDATE_TASK=true
